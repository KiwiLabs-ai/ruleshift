{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/monitor-sources",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/send-digests",
      "schedule": "0 * * * *"
    }
  ]
}
